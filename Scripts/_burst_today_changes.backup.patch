+void UBurstMeshStateSwitcherComponent::PollLeapFistDisplayToggle(float DeltaTime)
+{
+	FistToggleCooldownRemaining = FMath::Max(0.0f, FistToggleCooldownRemaining - DeltaTime);
+
+	if (!bEnableFistDisplayToggle)
+	{
+		return;
+	}
+
+	if (!bLeftHandPresent || LeftGrabStrength <= FistReleaseThreshold)
+	{
+		bLeftFistLatched = false;
+	}
+	if (!bRightHandPresent || RightGrabStrength <= FistReleaseThreshold)
+	{
+		bRightFistLatched = false;
+	}
+
+	if (!IsSingleHandPresent())
+	{
+		return;
+	}
+
+	const bool bUseLeftHand = bLeftHandPresent && !bRightHandPresent;
+	const float GrabStrength = bUseLeftHand ? LeftGrabStrength : RightGrabStrength;
+	const float Confidence = bUseLeftHand ? LeftHandConfidence : RightHandConfidence;
+	bool& bFistLatched = bUseLeftHand ? bLeftFistLatched : bRightFistLatched;
+
+	if (Confidence < MinHandConfidence || FistToggleCooldownRemaining > 0.0f)
+	{
+		return;
+	}
+
+	if (!bFistLatched && GrabStrength >= FistGrabThreshold)
+	{
+		ToggleDisplayActors();
+		bFistLatched = true;
+		FistToggleCooldownRemaining = FistToggleCooldownSeconds;
+	}
+}
+
+bool UBurstMeshStateSwitcherComponent::IsSingleHandPresent() const
+{
+	return bLeftHandPresent != bRightHandPresent;
+}
+
+void UBurstMeshStateSwitcherComponent::ToggleDisplayActors()
+{
+	SetDisplayToggleState(!bSealDisplayVisible);
+}
+
+void UBurstMeshStateSwitcherComponent::SetDisplayToggleState(bool bShowSeal)
+{
+	bSealDisplayVisible = bShowSeal;
+	SetDisplayActorVisible(FindDisplayActorByNameOrLabel(SealActorNameOrLabel), bShowSeal);
+	SetDisplayActorVisible(FindDisplayActorByNameOrLabel(BGActorNameOrLabel), !bShowSeal);
+
+	UE_LOG(LogTemp, Display, TEXT("BurstMeshStateSwitcher: fist display toggle -> %s."),
+		bShowSeal ? TEXT("Chinese_Seal_Pool_Animator") : TEXT("BG"));
+}
+
+AActor* UBurstMeshStateSwitcherComponent::FindDisplayActorByNameOrLabel(FName ActorNameOrLabel) const
+{
+	UWorld* World = GetWorld();
+	if (!World || ActorNameOrLabel.IsNone())
+	{
+		return nullptr;
+	}
+
+	const FString DesiredName = ActorNameOrLabel.ToString();
+	for (TActorIterator<AActor> It(World); It; ++It)
+	{
+		AActor* Actor = *It;
+		if (!Actor || Actor == GetOwner())
+		{
+			continue;
+		}
+
+		if (Actor->GetFName() == ActorNameOrLabel || Actor->ActorHasTag(ActorNameOrLabel)
+			|| Actor->GetActorNameOrLabel() == DesiredName)
+		{
+			return Actor;
+		}
+	}
+
+	return nullptr;
+}
+
+void UBurstMeshStateSwitcherComponent::SetDisplayActorVisible(AActor* Actor, bool bVisible) const
+{
+	if (!Actor)
+	{
+		return;
+	}
+
+	Actor->SetActorHiddenInGame(!bVisible);
+
+	TArray<USceneComponent*> SceneComponents;
+	Actor->GetComponents(SceneComponents);
+	for (USceneComponent* SceneComponent : SceneComponents)
+	{
+		if (SceneComponent)
+		{
+			SceneComponent->SetVisibility(bVisible, true);
+		}
+	}
+}
