# Unreal Engine generated folders (recursive)
**/Binaries/
**/DerivedDataCache/
**/Intermediate/
**/Saved/

# Build output per-plugin and per-project
Build/

# IDE/editor state
.vs/
.idea/
.claude/settings.local.json
*.VC.db
*.VC.VC.opendb
*.suo
*.user
*.userosscache
*.sln.docstates

# Build products and logs
*.log
*.obj
*.pdb
*.ilk
*.idb
*.tlog
*.lastbuildstate

# Unreal temporary files
*.tmp
*.cache
*.udebugsymbols
__pycache__/
*.pyc

# JavaScript dependencies
node_modules/

# Local screenshots and verification artifacts
Screenshots/

# Large third-party binaries (re-downloadable)
# Substance plugin native libs (installer provides these)
Plugins/Runtime/Substance/Libs/
# SocketIOClient is 700MB mostly Binaries/Intermediate, source only is fine
# But since Binaries/Intermediate are already excluded above, no extra rule needed

# FBX source art (large, can be re-exported)
# *.fbx

# UE cooked/packaged data
.egstore/

# OS noise
Thumbs.db
Desktop.ini
.DS_Store
